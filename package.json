{
  "name": "@cocaxcode/token-optimizer-mcp",
  "version": "0.2.7",
  "mcpName": "io.github.cocaxcode/token-optimizer-mcp",
  "description": "Orchestration + observability + coach layer for Claude Code token optimization. Measures tool usage, enforces budgets, advises on complementary tools (serena, RTK), and proactively surfaces savings tips.",
  "type": "module",
  "bin": {
    "token-optimizer-mcp": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "npm run build",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js -- --mcp"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude-code",
    "token-optimization",
    "observability",
    "budgets",
    "orchestration",
    "coach",
    "analytics",
    "cocaxcode",
    "claude",
    "cursor",
    "windsurf"
  ],
  "author": "cocaxcode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cocaxcode/token-optimizer-mcp.git"
  },
  "homepage": "https://github.com/cocaxcode/token-optimizer-mcp#readme",
  "bugs": {
    "url": "https://github.com/cocaxcode/token-optimizer-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.0"
  }
}
